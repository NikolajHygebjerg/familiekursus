# Airtable API nøgle - hent fra https://airtable.com/create/tokens
# Giv tokenet "data.records:read" og "data.records:write" scope for din base
AIRTABLE_API_KEY=patxxxxxxxxxxxxxxxxxxxx

# Vercel Blob til Mød os-billedeupload (opret i Vercel → Storage → Blob)
BLOB_READ_WRITE_TOKEN=

# Valgfri: Microsoft Forms- eller SharePoint-uploadside til Evaluering → Billedupload (iframe)
# Brug Forms-link med fil-upload for bedst resultat, fx https://forms.cloud.microsoft/e/xxxxx
NEXT_PUBLIC_BILLEUPLOAD_URL=
